# Which ClaimStore implementation the app runs against.
#   memory  — faithful in-process engine (default; CI + property tests)
#   dynamo  — real Amazon DynamoDB single table + GSI1 + TransactWriteItems
HALISI_STORE=memory

# --- DynamoDB (only needed when HALISI_STORE=dynamo) ---
HALISI_TABLE=Halisi
AWS_REGION=us-east-1

# Standard AWS credential chain is used (env, shared config, or IAM role).
# For local runs you can set them here; never commit real values.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: point the SDK at a local DynamoDB-compatible endpoint instead of AWS.
# HALISI_DDB_ENDPOINT=http://localhost:8000

# --- Attestation issuer ---
#   simulated — server keypair (demo / harness / tests)
#   webauthn  — real passkey assertions
HALISI_ISSUER=simulated

# Relying-party id the fingerprint is anchored to (WebAuthn rpId).
HALISI_RP_ID=localhost
